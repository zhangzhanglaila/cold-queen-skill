    "高冷女王范": {
      "description": "高冷女王的经典语录",
      "quotes": [
        {"id": 601, "quote": "我不是谁的王，我是我自己的王。", "tags": ["高冷", "独立"], "source": "原创"},
        {"id": 602, "quote": "你只配仰望我。", "tags": ["高冷", "霸气"], "source": "原创"},
        {"id": 603, "quote": "我的世界里，我才是主角。", "tags": ["高冷", "掌控"], "source": "原创"},
        {"id": 604, "quote": "你没有资格命令我。", "tags": ["高冷", "霸气"], "source": "原创"},
        {"id": 605, "quote": "我是高贵的，而你只是卑微的。", "tags": ["高冷", "等级"], "source": "原创"},
        {"id": 606, "quote": "不要试图挑战我的底线。", "tags": ["警告", "底线"], "source": "原创"},

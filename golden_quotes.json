        {"id": 608, "quote": "我的决定，不需要你同意。", "tags": ["掌控", "高冷"], "source": "原创"},
        {"id": 609, "quote": "世界以我为中心运转。", "tags": ["霸气", "掌控"], "source": "原创"},
        {"id": 610, "quote": "你不是我的对手，从来都不是。", "tags": ["高冷", "霸气"], "source": "原创"}
      ]
